{
    "productName": "LinVClipBoard",
    "version": "2.4.0",
    "identifier": "com.linvclipboard.app",
    "build": {
        "frontendDist": "../dist",
        "devUrl": "http://localhost:1420",
        "beforeDevCommand": "npm run dev",
        "beforeBuildCommand": "npm run build"
    },
    "app": {
        "windows": [
            {
                "title": "LinVClipBoard",
                "width": 420,
                "height": 520,
                "resizable": true,
                "minWidth": 320,
                "minHeight": 400,
                "maxWidth": 1800,
                "maxHeight": 900,
                "decorations": false,
                "transparent": true,
                "alwaysOnTop": true,
                "visible": true,
                "center": true,
                "skipTaskbar": true
            }
        ],
        "security": {
            "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: https://asset.localhost https://static.klipy.com data:; connect-src 'self' https://api.klipy.com https://api.github.com https://github.com https://objects.githubusercontent.com; script-src 'self'; font-src 'self' data:"
        }
    },
    "bundle": {
        "linux": {
            "deb": {
                "provides": ["linvclipboard"],
                "conflicts": ["linvclipboard"],
                "replaces": ["linvclipboard"],
                "desktopTemplate": "../../../install/deb-desktop.desktop",
                "postInstallScript": "../../../install/deb-postinst.sh",
                "files": {
                    "/usr/bin/clipd": "../../../target/release/clipd",
                    "/usr/bin/clipctl": "../../../target/release/clipctl",
                    "/usr/share/linvclipboard/clipd.service": "../../../install/clipd.service",
                    "/usr/share/icons/hicolor/128x128/apps/linvclipboard.png": "icons/icon.png"
                }
            }
        }
    },
    "plugins": {}
}