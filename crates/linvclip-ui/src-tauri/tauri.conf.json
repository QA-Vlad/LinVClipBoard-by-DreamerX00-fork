{
    "productName": "LinVClipBoard",
    "version": "1.0.1",
    "identifier": "com.linvclipboard.app",
    "build": {
        "frontendDist": "../dist",
        "devUrl": "http://localhost:1420",
        "beforeDevCommand": "npm run dev",
        "beforeBuildCommand": "npm run build"
    },
    "app": {
        "windows": [
            {
                "title": "LinVClipBoard",
                "width": 420,
                "height": 520,
                "resizable": false,
                "decorations": false,
                "transparent": true,
                "alwaysOnTop": true,
                "visible": true,
                "center": true,
                "skipTaskbar": true
            }
        ],
        "security": {
            "csp": null
        }
    },
    "plugins": {}
}